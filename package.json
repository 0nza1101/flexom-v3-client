{
  "name": "@0nza1101/flexom-v3-client",
  "version": "0.0.0",
  "description": "Node.js library to interact with the Flexom V3 API",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "client",
    "flexom",
    "flexom-v3"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/0nza1101/flexom-v3-client.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    "require": "./dist/index.js",
    "import": "./dist/index.mjs"
  },
  "engines": {
    "node": ">=14.16"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "package": "pnpm build --out-dir ./dist/dist/ && shx cp package.json ./dist/ && npm pack ./dist",
    "build-fast": "tsup src/index.ts --format cjs,esm --clean",
    "build": "pnpm build-fast --dts-resolve",
    "test": "vitest run --reporter verbose",
    "format": "npx prettier --write .",
    "prepublishOnly": "pnpm build"
  },
  "license": "MIT",
  "devDependencies": {
    "prettier": "2.6.2",
    "shx": "^0.3.4",
    "tsup": "5.12.8",
    "typescript": "4.6.4",
    "vite": "2.9.9",
    "vitest": "0.12.6"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "browser-or-node": "^2.0.0",
    "dotenv": "^16.0.1",
    "form-data": "^4.0.0",
    "formdata-node": "^4.3.2",
    "form-data-encoder": "^1.7.2",
    "retry-axios": "^3.0.0"
  }
}